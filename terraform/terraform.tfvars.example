aws_region    = "us-east-1"
project_name  = "ecommerce"
instance_type = "t3.small"

# t3.small is not available in us-east-1e; use a, b, c, d, or f
availability_zone = "us-east-1a"

# Create this key pair in EC2 → Key Pairs before running terraform apply
key_name = "your-learner-lab-key"

# Restrict SSH to your IP (recommended): "203.0.113.10/32"
ssh_cidr = "0.0.0.0/0"

# Optional: public repo to auto-deploy on first boot
# github_repo_url = "https://github.com/your-org/Ecommerce-mini-project.git"

db_password = "ChangeMeInLearnerLab123!"
